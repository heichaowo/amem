{
  "name": "amem-plugin",
  "version": "0.2.0",
  "description": "A-MEM agentic memory backend for OpenClaw — TypeScript rewrite",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --out-dir dist",
    "dev": "tsup src/index.ts --format cjs --watch",
    "consolidate": "tsx scripts/consolidate-memories.ts",
    "lint": "eslint src",
    "format": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "check:boundaries": "tsx scripts/check-boundaries.ts",
    "check": "npm run format && npm run lint && npm run check:boundaries"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@huggingface/transformers": "^3.5.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@types/uuid": "^10.0.0",
    "chromadb": "^1.9.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1"
  }
}
