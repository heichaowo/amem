{
  "name": "amem-plugin",
  "version": "0.3.1",
  "description": "A-MEM agentic memory backend for OpenClaw — TypeScript rewrite",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --out-dir dist",
    "dev": "tsup src/index.ts --format cjs --watch",
    "consolidate": "tsx scripts/consolidate-memories.ts",
    "lint": "eslint src",
    "format": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "check:boundaries": "tsx scripts/check-boundaries.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run format && npm run lint && npm run check:boundaries && npm run test",
    "docs:dev": "vitepress dev website",
    "docs:build": "vitepress build website",
    "docs:preview": "vitepress preview website"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@huggingface/transformers": "^3.5.0",
    "@node-rs/jieba": "^2.0.1",
    "@qdrant/js-client-rest": "^1.18.0",
    "@types/uuid": "^10.0.0",
    "chromadb": "^1.9.2",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@node-rs/jieba-darwin-arm64": "^2.0.1",
    "@node-rs/jieba-linux-x64-gnu": "^2.0.1"
  }
}
