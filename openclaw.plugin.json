{
  "id": "openclaw-amem",
  "name": "Memory (A-MEM v2)",
  "description": "A-MEM agentic memory backend for OpenClaw — Qdrant + Transformers.js, no Python required. Note construction, link generation, memory evolution.",
  "version": "0.4.1",
  "kind": "memory",
  "contracts": {
    "tools": [
      "memory_search",
      "memory_add",
      "memory_list",
      "memory_consolidate",
      "memory_quality_scan"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "topK": {
        "type": "number",
        "default": 5,
        "description": "Maximum number of memories to retrieve."
      },
      "agentId": {
        "type": "string",
        "default": "main",
        "description": "Agent namespace for memory isolation."
      }
    },
    "required": []
  }
}
