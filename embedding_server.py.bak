#!/usr/bin/env python3
"""
OpenAI-compatible embedding server using sentence-transformers.
Endpoint: POST /v1/embeddings
Port: 9884
"""
from fastapi import FastAPI
from pydantic import BaseModel
from sentence_transformers import SentenceTransformer
from typing import Union, Optional
import uvicorn
import time

MODEL_NAME = "paraphrase-multilingual-MiniLM-L12-v2"
EMBEDDING_DIM = 384
model = SentenceTransformer(MODEL_NAME)

app = FastAPI()

class EmbedRequest(BaseModel):
    input: Union[str, list[str]]
    model: str = MODEL_NAME
    encoding_format: Optional[str] = "float"
    dimensions: Optional[int] = None  # 接受但忽略，始终返回完整 384 维

@app.post("/v1/embeddings")
def embeddings(req: EmbedRequest):
    texts = [req.input] if isinstance(req.input, str) else req.input
    vecs = model.encode(texts, normalize_embeddings=True).tolist()
    return {
        "object": "list",
        "data": [
            {"object": "embedding", "index": i, "embedding": v}
            for i, v in enumerate(vecs)
        ],
        "model": req.model,
        "usage": {
            "prompt_tokens": sum(len(t.split()) for t in texts),
            "total_tokens": sum(len(t.split()) for t in texts),
        },
    }

@app.get("/v1/models")
def list_models():
    """让 openai JS SDK 能探测模型，避免 404"""
    return {
        "object": "list",
        "data": [
            {
                "id": MODEL_NAME,
                "object": "model",
                "created": int(time.time()),
                "owned_by": "local",
            }
        ],
    }

@app.get("/health")
def health():
    return {"status": "ok", "model": MODEL_NAME, "dim": EMBEDDING_DIM}

if __name__ == "__main__":
    uvicorn.run(app, host="127.0.0.1", port=9884)
