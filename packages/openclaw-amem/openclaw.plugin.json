{
  "id": "openclaw-amem",
  "name": "Memory (A-MEM v2)",
  "description": "OpenClaw memory plugin implementing A-MEM — memories evolve, not just accumulate. Graph linking, hybrid retrieval, LLM-driven evolution. No Python.",
  "version": "1.2.1",
  "kind": "memory",
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.3.24"
    },
    "build": {
      "openclawVersion": "2026.7.1-2"
    }
  },
  "contracts": {
    "tools": [
      "memory_search",
      "memory_add",
      "memory_list",
      "memory_consolidate",
      "memory_quality_scan"
    ]
  },
  "setup": {
    "providers": [
      {
        "id": "amem",
        "envVars": [
          "AMEM_LLM_PROVIDER",
          "AMEM_LLM_API_KEY",
          "OPENAI_API_KEY",
          "AMEM_LLM_BASE_URL",
          "AMEM_LLM_MODEL",
          "AMEM_COLLECTION",
          "AMEM_DATA_DIR",
          "AMEM_EVO_COUNTER_PATH",
          "AMEM_REVIEW_DIR",
          "AMEM_PROMPT_LOCALE"
        ]
      }
    ]
  },
  "providerEndpoints": [
    {
      "endpointClass": "qdrant",
      "hosts": [
        "localhost"
      ],
      "baseUrls": [
        "http://localhost:6333"
      ],
      "note": "Local Qdrant vector store for memory embeddings."
    },
    {
      "endpointClass": "anthropic",
      "hosts": [
        "api.anthropic.com"
      ],
      "hostSuffixes": [
        ".anthropic.com"
      ],
      "note": "Default LLM for note construction / link generation / evolution; override the base URL via AMEM_LLM_BASE_URL."
    },
    {
      "endpointClass": "openai",
      "hosts": [
        "api.openai.com"
      ],
      "hostSuffixes": [
        ".openai.com"
      ],
      "note": "Alternate LLM when AMEM_LLM_PROVIDER=openai — the OpenAI Chat Completions API, or any compatible gateway (DeepSeek, OpenRouter, Groq, Together, Ollama, vLLM) selected via AMEM_LLM_BASE_URL."
    }
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "topK": {
        "type": "number",
        "default": 5,
        "description": "Maximum number of memories to retrieve."
      },
      "agentId": {
        "type": "string",
        "default": "main",
        "description": "Agent namespace for memory isolation."
      },
      "collection": {
        "type": "string",
        "description": "Qdrant collection name (mode A shared default)."
      },
      "agents": {
        "type": "object",
        "description": "Per-agent overrides keyed by agentId.",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "agentId": {
              "type": "string",
              "description": "Override the effective agentId namespace."
            },
            "collection": {
              "type": "string",
              "description": "Dedicated collection → mode B isolation."
            }
          }
        }
      }
    },
    "required": []
  }
}
