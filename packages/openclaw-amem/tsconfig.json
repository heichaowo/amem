{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    // The `amem` engine is inlined by the bundler (see tsup.config.ts), not a
    // package dependency, so tsc is pointed at its built declarations
    // (packages/amem-core/dist/index.d.ts) to type the import. A declaration
    // file is exempt from the rootDir constraint.
    "paths": {
      "amem": ["../amem-core/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
