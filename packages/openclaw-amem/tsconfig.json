{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    // amem-core is inlined by the bundler (see tsup.config.ts), not a package
    // dependency, so tsc is pointed at its built declarations — the same
    // dist/index.d.ts the workspace symlink used to resolve — to type the
    // import. A declaration file is exempt from the rootDir constraint.
    "paths": {
      "amem-core": ["../amem-core/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
