{
  "name": "@heichaowo/amem-core",
  "version": "0.2.0",
  "description": "The agentic memory engine — notes that construct, link, and evolve like a Zettelkasten, on Qdrant + Transformers.js. No Python. Framework-agnostic.",
  "license": "MIT",
  "homepage": "https://amem.owo.lc",
  "bugs": {
    "url": "https://github.com/heichaowo/amem/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration --passWithNoTests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@huggingface/transformers": "^4.2.0",
    "@node-rs/jieba": "^2.0.1",
    "@qdrant/js-client-rest": "^1.18.0",
    "openai": "^6.48.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.7.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "@node-rs/jieba-darwin-arm64": "^2.0.1",
    "@node-rs/jieba-linux-x64-gnu": "^2.0.1"
  },
  "keywords": [
    "a-mem",
    "agentic-memory",
    "agent-memory",
    "memory",
    "qdrant",
    "vector-memory",
    "llm-memory",
    "transformers",
    "embeddings"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heichaowo/amem.git",
    "directory": "packages/amem-core"
  },
  "publishConfig": {
    "access": "public"
  }
}
