{
  "name": "@heichaowo/amem-api",
  "version": "0.1.1",
  "private": true,
  "description": "amem-api — the single-writer memory service for the amem stack (HTTP + MCP).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "amem-api": "./dist/cli.js",
    "amem-mcp": "./dist/mcp-cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "amem": "workspace:*",
    "fastify": "^5.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "amem",
    "agentic-memory",
    "memory-service",
    "qdrant",
    "fastify",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heichaowo/amem.git",
    "directory": "packages/amem-api"
  },
  "homepage": "https://amem.owo.lc",
  "bugs": {
    "url": "https://github.com/heichaowo/amem/issues"
  }
}
